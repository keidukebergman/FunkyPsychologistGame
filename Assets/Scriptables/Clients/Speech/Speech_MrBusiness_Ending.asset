  m_Script: {fileID: 11500000, guid: 7a9e7d0954553594ebb4351359a0d4e5, type: 3}
  m_Name: Speech_MrBusiness_Ending
  m_EditorClassIdentifier: Assembly-CSharp::ClientSpeech
  Clip: {fileID: 8300000, guid: 89d828c1b0b40444dbeff6afeb4e111b, type: 3}
  Subtitles: "I don\u2019t really think that she\u2019s the right woman to stay married
    to, but I also don\u2019t want her to suffer just because I made this awful business
    deal, you know? Honestly, any asset I could give her would soften the blow, and
    make it easier for the kids to focus in school. June is the worst month for signing
    contracts, this is so bullshit. Should I give her the vacation house?"
