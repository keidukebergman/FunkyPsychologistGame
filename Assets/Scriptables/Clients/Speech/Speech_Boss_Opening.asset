  m_Script: {fileID: 11500000, guid: 7a9e7d0954553594ebb4351359a0d4e5, type: 3}
  m_Name: Speech_Boss_Opening
  m_EditorClassIdentifier: Assembly-CSharp::ClientSpeech
  Clip: {fileID: 8300000, guid: 44211c92b1ed98d40937cebcb11e8d98, type: 3}
  Subtitles: "How are you doing? I don\u2019t want to be a bother, but you know -
    These tender souls are in need of a nurturing hand, and I was just thinking about
    how you\u2019re such a good fit for this job!  Anyway, I was just sort of calling
    to ask a teensy-weensy favour - Nothing big, it\u2019s just\u2026 I need you
    to work Sundays from now on, ok? The mental support hotline is overflowing -
    Don\u2019t you feel like being a change in this overwhelming world? Of course
    we all have to do what little we can, and I just know that you can do some true
    good in here.  Also, I know you\u2019ve had issues falling asleep recently -
    Did you get that checked out? "
